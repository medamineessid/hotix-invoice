<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>hotix_icon.ico</ApplicationIcon>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
  </PropertyGroup>

  <!-- ── Pre-build: embed git commit hash (or fallback timestamp) ── -->
  <!-- Inputs/Outputs intentionally omitted: git hash must be regenerated on every build,
       not cached against .csproj changes alone. -->
  <Target Name="GenerateBuildInfo" BeforeTargets="CoreCompile">
    <Exec Command="git rev-parse --short HEAD" ConsoleToMSBuild="true" IgnoreExitCode="true" StandardOutputImportance="Low">
      <Output TaskParameter="ConsoleOutput" PropertyName="_GitHash" />
    </Exec>
    <PropertyGroup>
      <_BuildHash Condition="'$(_GitHash)' != ''">$(_GitHash.Trim())</_BuildHash>
      <_BuildHash Condition="'$(_GitHash)' == ''">$([System.DateTime]::UtcNow.ToString("yyyyMMdd-HHmmss"))</_BuildHash>
      <_BuildTimestamp>$([System.DateTime]::UtcNow.ToString("yyyy-MM-dd HH:mm:ss UTC"))</_BuildTimestamp>
    </PropertyGroup>
    <ItemGroup>
      <_BuildInfoLines Include="// &lt;auto-generated&gt; by GenerateBuildInfo target&lt;/auto-generated&gt;" />
      <_BuildInfoLines Include="namespace Hotix.InvoiceClient%3B" />
      <_BuildInfoLines Include="internal static class BuildInfo" />
      <_BuildInfoLines Include="{" />
      <_BuildInfoLines Include="    public const string CommitHash = &quot;$(_BuildHash)&quot;%3B" />
      <_BuildInfoLines Include="    public const string BuildTimestamp = &quot;$(_BuildTimestamp)&quot;%3B" />
      <_BuildInfoLines Include="    public const string AppVersion = &quot;1.0.0&quot;%3B" />
      <_BuildInfoLines Include="}" />
    </ItemGroup>
    <WriteLinesToFile File="$(IntermediateOutputPath)BuildInfo.g.cs" Lines="@(_BuildInfoLines, '%0A')" Overwrite="true" />
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)BuildInfo.g.cs" />
    </ItemGroup>
  </Target>

  <Target Name="CopyAssets" AfterTargets="Build">
    <ItemGroup>
      <ServerFiles Include="$(ProjectDir)..\server\*.py" />
      <SettingsFile Include="$(ProjectDir)..\server\appsettings.json" />
      <ResourceFiles Include="$(ProjectDir)Resources\*.json" />
    </ItemGroup>
    <Copy SourceFiles="@(ServerFiles)" DestinationFolder="$(OutputPath)\server" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(SettingsFile)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(ResourceFiles)" DestinationFolder="$(OutputPath)\Resources" SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <Compile Remove="Program.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.0" />
    <PackageReference Include="Sentry" Version="6.6.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="hotix_icon.ico" />
  </ItemGroup>

</Project>

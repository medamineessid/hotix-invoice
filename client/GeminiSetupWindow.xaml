<Window x:Class="Hotix.InvoiceClient.GeminiSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Hotix.InvoiceClient"
        Title="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiTitle]}"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Opacity="0"
        x:Name="ConfigWindow">

    <Window.Resources>
        <!-- Window entrance: fade + scale -->
        <Storyboard x:Key="StoryboardWindowEnter">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.25"
                             EasingFunction="{StaticResource EaseOut}" />
        </Storyboard>

        <Storyboard x:Key="SpinnerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360"
                             Duration="0:0:1.2" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource StoryboardWindowEnter}" />
        </EventTrigger>
    </Window.Triggers>

    <Window.RenderTransform>
        <TransformGroup>
            <ScaleTransform ScaleX="1" ScaleY="1" />
            <TranslateTransform />
        </TransformGroup>
    </Window.RenderTransform>

    <Border Background="{StaticResource BrushOverlay}">
        <Border Style="{StaticResource DialogStyle}"
                MinWidth="420" MaxWidth="720"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="32">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          PanningDeceleration="0.003"
                          BorderThickness="0">
            <Grid MinHeight="200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="28,28,28,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="HeaderTitle"
                                   Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiHeader]}"
                                   Style="{StaticResource TextSectionHeading}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="HeaderDescription"
                                   Style="{StaticResource TextBody}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   TextWrapping="Wrap"
                                   Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiDescription]}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="CloseButton"
                            Style="{StaticResource ButtonIconStyle}"
                            Width="32" Height="32"
                            VerticalAlignment="Top"
                            Content="✕"
                            FontSize="14"
                            Click="CloseButton_Click"
                            Margin="16,0,0,0"
                            ToolTip="Close" />
                </Grid>

                <!-- Body -->
                <StackPanel Grid.Row="1" Margin="28,0,28,0">
                    <!-- Provider selector -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Padding="4,2"
                                CornerRadius="{StaticResource RadiusSmall}"
                                Background="{StaticResource BrushAltBackground}"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="ProviderGeminiRadio"
                                             Content="Gemini"
                                             GroupName="AIProvider"
                                             Style="{StaticResource RadioButtonStyle}"
                                             Margin="12,8,4,8"
                                             Checked="Provider_Checked" />
                                <RadioButton x:Name="ProviderGrokRadio"
                                             Content="Grok (xAI)"
                                             GroupName="AIProvider"
                                             Style="{StaticResource RadioButtonStyle}"
                                             Margin="4,8,12,8"
                                             Checked="Provider_Checked" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Key label (changes based on provider) -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="KeyLabel"
                                   Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiSubheader]}"
                                   Style="{StaticResource CardLabelStyle}"
                                   TextWrapping="Wrap" />
                        <Grid VerticalAlignment="Center" Margin="4,0,0,6">
                            <TextBlock x:Name="InfoKeyIcon"
                                       Text="ⓘ"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="InfoKeyIcon_Click" />
                            <Popup x:Name="InfoKeyPopup"
                                   PlacementTarget="{Binding ElementName=InfoKeyIcon}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource BrushSurface}"
                                        BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14,10"
                                        MaxWidth="300"
                                        Effect="{StaticResource ShadowCard}">
                                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[InfoGeminiKey]}"
                                               Style="{StaticResource TextCaption}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Key input container with overlapping PasswordBox + TextBox -->
                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="GeminiKeyBox"
                                         Style="{StaticResource PasswordBoxStyle}"
                                         PasswordChanged="GeminiKeyBox_PasswordChanged" />
                            <TextBox x:Name="GeminiKeyTextBox"
                                     Style="{StaticResource TextBoxStyle}"
                                     Visibility="Collapsed"
                                     TextChanged="GeminiKeyTextBox_TextChanged" />
                        </Grid>

                        <!-- Show/Hide toggle button (eye icon) -->
                        <ToggleButton x:Name="KeyVisibilityToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource ButtonIconStyle}"
                                      Width="36" Height="36"
                                      Margin="4,0,4,0"
                                      VerticalAlignment="Center"
                                      IsChecked="False"
                                      Click="KeyVisibilityToggle_Click"
                                      ToolTip="Show/hide key">
                            <TextBlock x:Name="ToggleEyeIcon" Text="👁" FontSize="14" />
                        </ToggleButton>

                        <TextBlock x:Name="KeyStatusIcon"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0"
                                   FontSize="12"
                                   FontWeight="{StaticResource FontWeightMedium}" />
                    </Grid>

                    <!-- Model selector (visible by default, populated with known models) -->
                    <StackPanel x:Name="ModelSelector"
                                Margin="0,16,0,0"
                                Visibility="Visible">
                        <TextBlock x:Name="ModelLabel"
                                   Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiModelLabel]}"
                                   Style="{StaticResource CardLabelStyle}" />
                        <ComboBox x:Name="ModelCombo"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Width="360"
                                  HorizontalAlignment="Left"
                                  MinHeight="36" />
                    </StackPanel>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Spinning indicator -->
                        <Grid x:Name="SpinnerIndicator"
                              Grid.Column="0"
                              Width="16" Height="16"
                              Visibility="Collapsed"
                              Margin="0,0,8,0"
                              VerticalAlignment="Top">
                            <Ellipse Width="16" Height="16"
                                     Stroke="{StaticResource BrushAccent}"
                                     StrokeThickness="2"
                                     Opacity="0.2" />
                            <Path x:Name="SpinnerArc"
                                  Width="16" Height="16"
                                  Stretch="None"
                                  Stroke="{StaticResource BrushAccent}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate" />
                                </Path.RenderTransform>
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="8,2" IsClosed="False">
                                            <ArcSegment Point="8,14"
                                                        Size="6,6"
                                                        SweepDirection="Clockwise"
                                                        IsLargeArc="True" />
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>
                        </Grid>

                        <!-- Status / error message -->
                        <TextBlock x:Name="MessageLabel"
                                   Grid.Column="1"
                                   Style="{StaticResource TextCaption}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   MaxHeight="120" />
                    </Grid>
                </StackPanel>

                <!-- Buttons (intentional order: low→high importance) -->
                <Border Grid.Row="2" Margin="28,20,28,28">
                    <WrapPanel HorizontalAlignment="Right"
                               Orientation="Horizontal">

                        <Button x:Name="IgnoreButton"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiIgnoreBtn]}"
                                Style="{StaticResource ButtonSecondaryStyle}"
                                MinWidth="80"
                                Margin="0,0,8,8"
                                Click="Ignore_Click" />
                        <Button x:Name="ClearKeyButton"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiClearBtn]}"
                                Style="{StaticResource ButtonDangerStyle}"
                                MinWidth="100"
                                Margin="0,0,8,8"
                                Click="ClearKey_Click" />
                        <Button x:Name="GetKeyButton"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiGetKeyBtn]}"
                                Style="{StaticResource ButtonSecondaryStyle}"
                                MinWidth="130"
                                Margin="0,0,8,8"
                                Click="GetApiKey_Click" />
                        <Button x:Name="SaveButton"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[GeminiSaveBtn]}"
                                Style="{StaticResource ButtonPrimaryStyle}"
                                MinWidth="100"
                                Margin="0,0,0,8"
                                Click="Save_Click" />
                    </WrapPanel>
                </Border>
            </Grid>
            </ScrollViewer>
        </Border>
    </Border>
</Window>

<Window x:Class="Hotix.InvoiceClient.GeminiSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration Gemini" Height="380" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Topmost="True">

    <Window.RenderTransform>
        <TransformGroup>
            <ScaleTransform ScaleX="1" ScaleY="1" />
            <TranslateTransform />
        </TransformGroup>
    </Window.RenderTransform>

    <Border Background="{StaticResource BrushOverlay}">
        <Border Style="{StaticResource DialogStyle}"
                Width="460"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Configuration optionnelle"
                               Style="{StaticResource TextSectionHeading}" />
                    <TextBlock Text="Clé API Gemini"
                               Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Body -->
                <StackPanel Grid.Row="1">
                    <TextBlock Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24">
                        Pour une meilleure précision d'extraction, vous pouvez configurer une clé API Gemini gratuite. Sans clé, l'extraction locale (OCR) reste entièrement disponible.
                    </TextBlock>

                    <TextBlock Text="Clé API Gemini" Style="{StaticResource CardLabelStyle}" />
                    <PasswordBox x:Name="GeminiKeyBox"
                                 Style="{StaticResource PasswordBoxStyle}"
                                 Tag="Collez votre clé ici..." />

                    <TextBlock x:Name="MessageLabel"
                               Style="{StaticResource TextCaption}"
                               Margin="0,12,0,0" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Content="Obtenir une clé gratuite"
                            Style="{StaticResource ButtonSecondaryStyle}"
                            Width="170"
                            Margin="0,0,12,0"
                            Click="GetApiKey_Click" />
                    <Button Content="Ignorer"
                            Style="{StaticResource ButtonSecondaryStyle}"
                            Width="90"
                            Margin="0,0,12,0"
                            Click="Ignore_Click" />
                    <Button Content="Enregistrer"
                            Style="{StaticResource ButtonPrimaryStyle}"
                            Width="120"
                            Click="Save_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>

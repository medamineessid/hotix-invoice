<Window x:Class="Hotix.InvoiceClient.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Démarrage" Height="220" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True">
    
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#C0392B" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top Header -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Width="30" Height="24" Background="#C0392B" CornerRadius="4" />
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="HOTIX" FontSize="18" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Extraction de Factures" FontSize="12" Foreground="#A0A0A0" />
                </StackPanel>
            </StackPanel>

            <!-- Loading Dots Animation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse x:Name="Dot1" Width="10" Height="10" Fill="#C0392B" Margin="5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <Ellipse x:Name="Dot2" Width="10" Height="10" Fill="#C0392B" Margin="5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.4">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <Ellipse x:Name="Dot3" Width="10" Height="10" Fill="#C0392B" Margin="5">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.8">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </StackPanel>

            <!-- Status Label -->
            <TextBlock Grid.Row="2" x:Name="StatusLabel"
                       Text="{Binding StatusMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                       Foreground="#A0A0A0" FontSize="12" HorizontalAlignment="Center" />
        </Grid>
    </Border>
</Window>

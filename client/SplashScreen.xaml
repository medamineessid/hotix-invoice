<Window x:Class="Hotix.InvoiceClient.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HOTIX" Height="280" Width="440"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True">

    <Border Background="{StaticResource BrushSurface}"
            CornerRadius="{StaticResource RadiusLarge}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            Effect="{StaticResource ShadowDialog}">

        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- Logo + Title -->
                <RowDefinition Height="*" />       <!-- Geometric artwork -->
                <RowDefinition Height="Auto" />    <!-- Status -->
            </Grid.RowDefinitions>

            <!-- Logo Area -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                <Border Width="40" Height="40"
                        Background="{StaticResource BrushAccent}"
                        CornerRadius="10"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16" />
                <TextBlock Text="HOTIX"
                           Style="{StaticResource TextSectionHeading}"
                           FontWeight="{StaticResource FontWeightLight}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Extraction de Factures"
                           Style="{StaticResource TextCaption}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Geometric Artwork (animated composition) -->
            <Grid Grid.Row="1" Width="160" Height="80" HorizontalAlignment="Center">
                <Border Width="48" Height="48"
                        Background="{StaticResource BrushGeometricFill}"
                        CornerRadius="6"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top" />
                <Border Width="24" Height="24"
                        Background="{StaticResource BrushAccent}"
                        CornerRadius="4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,16,0" />
                <Border Width="80" Height="1"
                        Background="{StaticResource BrushBorder}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                <Border Width="8" Height="8"
                        Background="{StaticResource BrushTextPrimary}"
                        CornerRadius="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0" />
            </Grid>

            <!-- Status -->
            <TextBlock Grid.Row="2"
                       x:Name="StatusLabel"
                       Text="{Binding StatusMessage, RelativeSource={RelativeSource AncestorType=Window}}"
                       Style="{StaticResource TextCaption}"
                       HorizontalAlignment="Center"
                       Margin="0,24,0,0" />
        </Grid>
    </Border>
</Window>

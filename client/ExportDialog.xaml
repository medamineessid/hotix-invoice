<Window x:Class="Hotix.InvoiceClient.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Hotix.InvoiceClient"
        Title="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportTitle]}"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Opacity="0"
        MinWidth="420">

    <Window.Resources>
        <Storyboard x:Key="StoryboardWindowEnter">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.25"
                             EasingFunction="{StaticResource EaseOut}" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource StoryboardWindowEnter}" />
        </EventTrigger>
    </Window.Triggers>

    <Border Background="{StaticResource BrushOverlay}">
        <Border Style="{StaticResource DialogStyle}"
                Width="460"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportTitle]}"
                               Style="{StaticResource TextSectionHeading}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportDescription]}"
                               Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- Body: Mode selection cards -->
                <StackPanel Grid.Row="1">
                    <!-- Create New card -->
                    <Border x:Name="NewCard"
                            CornerRadius="{StaticResource RadiusMedium}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            Padding="16,14"
                            Margin="0,0,0,12"
                            Cursor="Hand"
                            MouseLeftButtonDown="NewCard_Click"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="2"
                                    Background="Transparent"
                                    VerticalAlignment="Top"
                                    Margin="0,2,14,0">
                                <Border x:Name="NewRadioDot"
                                        Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{StaticResource BrushAccent}"
                                        Visibility="Collapsed" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportNewOption]}"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="{StaticResource FontWeightMedium}" />
                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportNewDesc]}"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Append to Existing card -->
                    <Border x:Name="AppendCard"
                            CornerRadius="{StaticResource RadiusMedium}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            Padding="16,14"
                            Cursor="Hand"
                            MouseLeftButtonDown="AppendCard_Click"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="2"
                                    Background="Transparent"
                                    VerticalAlignment="Top"
                                    Margin="0,2,14,0">
                                <Border x:Name="AppendRadioDot"
                                        Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{StaticResource BrushAccent}"
                                        Visibility="Collapsed" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportAppendOption]}"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="{StaticResource FontWeightMedium}" />
                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportAppendDesc]}"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Footer: buttons -->
                <Border Grid.Row="2" Margin="0,24,0,0">
                    <Grid HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlCancelBtn]}"
                                Style="{StaticResource ButtonSecondaryStyle}"
                                MinWidth="80"
                                Click="Cancel_Click" />
                        <Button Grid.Column="2"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportContinue]}"
                                Style="{StaticResource ButtonPrimaryStyle}"
                                MinWidth="120"
                                IsDefault="True"
                                Click="Continue_Click"
                                x:Name="ContinueButton" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>

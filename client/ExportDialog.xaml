<Window x:Class="Hotix.InvoiceClient.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Hotix.InvoiceClient"
        Title="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportTitle]}"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Opacity="0"
        MinWidth="460">

    <Window.Resources>
        <Storyboard x:Key="StoryboardWindowEnter">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.25"
                             EasingFunction="{StaticResource EaseOut}" />
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource StoryboardWindowEnter}" />
        </EventTrigger>
    </Window.Triggers>

    <Border Background="{StaticResource BrushOverlay}">
        <Border Style="{StaticResource DialogStyle}"
                Width="480"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportTitle]}"
                               Style="{StaticResource TextSectionHeading}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportDescription]}"
                               Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- Body: Filter options + Destination -->
                <StackPanel Grid.Row="1">

                    <!-- Filter section -->
                    <TextBlock Text="Filter:"
                               Style="{StaticResource CardLabelStyle}"
                               Margin="0,0,0,10" />

                    <!-- Results Only card -->
                    <Border x:Name="FilterResultsCard"
                            CornerRadius="{StaticResource RadiusMedium}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            Padding="16,14"
                            Margin="0,0,0,10"
                            Cursor="Hand"
                            MouseLeftButtonDown="FilterResultsOnly_Click"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="2"
                                    Background="Transparent"
                                    VerticalAlignment="Top"
                                    Margin="0,2,14,0">
                                <Border x:Name="FilterResultsDot"
                                        Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{StaticResource BrushAccent}"
                                        Visibility="Collapsed" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Results Only (complete invoices)"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="{StaticResource FontWeightMedium}" />
                                <TextBlock Text="Export only invoices with all 8 fields filled"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Missing Only card -->
                    <Border x:Name="FilterMissingCard"
                            CornerRadius="{StaticResource RadiusMedium}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            Padding="16,14"
                            Margin="0,0,0,10"
                            Cursor="Hand"
                            MouseLeftButtonDown="FilterMissingOnly_Click"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="2"
                                    Background="Transparent"
                                    VerticalAlignment="Top"
                                    Margin="0,2,14,0">
                                <Border x:Name="FilterMissingDot"
                                        Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{StaticResource BrushAccent}"
                                        Visibility="Collapsed" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Missing Only (incomplete invoices)"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="{StaticResource FontWeightMedium}" />
                                <TextBlock Text="Export only invoices with at least 1 empty field"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Both card -->
                    <Border x:Name="FilterBothCard"
                            CornerRadius="{StaticResource RadiusMedium}"
                            BorderBrush="{StaticResource BrushAccent}"
                            BorderThickness="2"
                            Padding="16,14"
                            Margin="0,0,0,20"
                            Cursor="Hand"
                            MouseLeftButtonDown="FilterBoth_Click"
                            Background="{StaticResource BrushSelected}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    BorderBrush="{StaticResource BrushAccent}"
                                    BorderThickness="2"
                                    Background="Transparent"
                                    VerticalAlignment="Top"
                                    Margin="0,2,14,0">
                                <Border x:Name="FilterBothDot"
                                        Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{StaticResource BrushAccent}"
                                        Visibility="Visible" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Both (all data)"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="{StaticResource FontWeightMedium}" />
                                <TextBlock Text="Export all invoices, empty fields marked as [MISSING]"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Destination section -->
                    <Border x:Name="DestinationSeparator"
                            Height="1"
                            Background="{StaticResource BrushBorder}"
                            Margin="0,0,0,16" />

                    <TextBlock Text="Destination:"
                               Style="{StaticResource CardLabelStyle}"
                               Margin="0,0,0,10" />

                    <!-- Append checkbox card -->
                    <Border x:Name="AppendCard"
                            CornerRadius="{StaticResource RadiusMedium}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            Padding="16,14"
                            Margin="0,0,0,4"
                            Cursor="Hand"
                            MouseLeftButtonDown="AppendCard_Click"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      x:Name="AppendCheckBox"
                                      VerticalAlignment="Top"
                                      Margin="0,2,14,0"
                                      Style="{StaticResource CheckBoxStyle}"
                                      Checked="AppendCheckBox_Changed"
                                      Unchecked="AppendCheckBox_Changed" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Append to existing file"
                                           Style="{StaticResource TextBody}"
                                           FontWeight="{StaticResource FontWeightMedium}" />
                                <TextBlock Text="Add data to an existing Excel workbook instead of creating a new one"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Footer: buttons -->
                <Border Grid.Row="2" Margin="0,24,0,0">
                    <Grid HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlCancelBtn]}"
                                Style="{StaticResource ButtonSecondaryStyle}"
                                MinWidth="80"
                                Click="Cancel_Click" />
                        <Button Grid.Column="2"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportContinue]}"
                                Style="{StaticResource ButtonPrimaryStyle}"
                                MinWidth="120"
                                IsDefault="True"
                                Click="Continue_Click"
                                x:Name="ContinueButton" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>

<Window x:Class="Hotix.InvoiceClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:Hotix.InvoiceClient.Controls"
        Title="HOTIX — Extraction de Factures"
        Icon="pack://application:,,,/hotix_icon.ico"
        Width="1280"
        Height="820"
        MinWidth="960"
        MinHeight="640"
        Background="{StaticResource BrushBackground}"
        Foreground="{StaticResource BrushTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        FontSize="{StaticResource FontSizeBody}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <!-- WindowChrome for native resize behavior -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="F5"     Command="{Binding StartExtractionCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelExtractionCommand}" />
        <KeyBinding Key="E"      Modifiers="Ctrl" Command="{Binding ExportExcelCommand}" />
    </Window.InputBindings>

    <!-- Window Fade-In on Load -->
    <Window.RenderTransform>
        <TransformGroup>
            <ScaleTransform ScaleX="1" ScaleY="1" />
            <TranslateTransform />
        </TransformGroup>
    </Window.RenderTransform>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource StoryboardWindowFadeIn}" />
        </EventTrigger>
    </Window.Triggers>

    <!-- ══ ROOT GRID: Sidebar | Main ══ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════
             SIDEBAR
             ═══════════════════════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource SidebarStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />   <!-- Logo -->
                    <RowDefinition Height="*" />       <!-- Navigation -->
                    <RowDefinition Height="Auto" />    <!-- Quote -->
                    <RowDefinition Height="Auto" />    <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- ── Logo Area ── -->
                <StackPanel Grid.Row="0" Margin="24,32,24,48">
                    <Border Width="32" Height="32"
                            Background="{StaticResource BrushAccent}"
                            CornerRadius="8"
                            Margin="0,0,0,16" />
                    <TextBlock Text="HOTIX" Style="{StaticResource SidebarLogoStyle}" />
                    <TextBlock Text="Extraction de Factures"
                               Style="{StaticResource TextCaption}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- ── Navigation ── -->
                <StackPanel Grid.Row="1" Margin="12,0,12,0">
                    <TextBlock Text="Navigation" Style="{StaticResource SidebarSectionLabel}" />

                    <!-- Extraction Nav Item (selected by default) -->
                    <Border x:Name="NavExtraction" Style="{StaticResource NavItemStyle}" MouseLeftButtonDown="NavExtraction_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 2px vertical indicator -->
                            <Border Grid.Column="0" x:Name="NavExtractionIndicator"
                                    Width="2" Height="20"
                                    Background="{StaticResource BrushTextPrimary}"
                                    CornerRadius="1"
                                    VerticalAlignment="Center" />

                            <!-- Icon -->
                            <TextBlock Grid.Column="0" Text="◇" Style="{StaticResource NavIconStyle}" Margin="16,0,12,0" />

                            <!-- Text -->
                            <TextBlock Grid.Column="1" x:Name="NavExtractionText"
                                       Text="Extraction" Style="{StaticResource NavTextSelectedStyle}" />

                            <!-- Red square accent -->
                            <Border Grid.Column="2" Style="{StaticResource NavRedSquareStyle}" />
                        </Grid>
                    </Border>

                    <!-- Settings Nav Item -->
                    <Border x:Name="NavSettings" Style="{StaticResource NavItemStyle}" MouseLeftButtonDown="NavSettings_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" x:Name="NavSettingsIndicator"
                                    Width="2" Height="0"
                                    Background="{StaticResource BrushTextPrimary}"
                                    CornerRadius="1"
                                    VerticalAlignment="Center"
                                    Opacity="0" />

                            <TextBlock Grid.Column="0" Text="◈" Style="{StaticResource NavIconStyle}" Margin="16,0,12,0" />
                            <TextBlock Grid.Column="1" x:Name="NavSettingsText"
                                       Text="Configuration" Style="{StaticResource NavTextStyle}" />
                        </Grid>
                    </Border>

                    <!-- About Nav Item -->
                    <Border x:Name="NavAbout" Style="{StaticResource NavItemStyle}" MouseLeftButtonDown="NavAbout_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" x:Name="NavAboutIndicator"
                                    Width="2" Height="0"
                                    Background="{StaticResource BrushTextPrimary}"
                                    CornerRadius="1"
                                    VerticalAlignment="Center"
                                    Opacity="0" />

                            <TextBlock Grid.Column="0" Text="○" Style="{StaticResource NavIconStyle}" Margin="16,0,12,0" />
                            <TextBlock Grid.Column="1" x:Name="NavAboutText"
                                       Text="À propos" Style="{StaticResource NavTextStyle}" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Inspirational Quote ── -->
                <StackPanel Grid.Row="2" Margin="24,0,24,32">
                    <Border Height="1" Background="{StaticResource BrushBorder}" Margin="0,0,0,16" />
                    <TextBlock Text="« La clarté est la seule beauté. »"
                               Style="{StaticResource SidebarQuoteStyle}" />
                    <TextBlock Text="— Kazimir Malevich"
                               Style="{StaticResource TextMetadata}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- ── Footer ── -->
                <StackPanel Grid.Row="3" Margin="24,0,24,20">
                    <TextBlock Text="v1.0.0" Style="{StaticResource SidebarFooterStyle}" />
                    <TextBlock Text="HOTIX" Style="{StaticResource SidebarFooterStyle}" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════
             MAIN WORKSPACE
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{StaticResource BrushAltBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />   <!-- Title Bar -->
                <RowDefinition Height="*" />     <!-- Content -->
                <RowDefinition Height="44" />    <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- ── Custom Title Bar ── -->
            <Border Grid.Row="0"
                    BorderThickness="0,0,0,0"
                    Background="{StaticResource BrushBackground}">
                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource TextCaption}"
                               Text="HOTIX — Extraction de Factures"
                               VerticalAlignment="Center"
                               Margin="32,0,0,0" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Button Style="{StaticResource ButtonIconStyle}" Content="─" Click="MinimizeButton_Click" />
                        <Button Style="{StaticResource ButtonIconStyle}" Content="□" Click="MaximizeButton_Click" />
                        <Button Style="{StaticResource ButtonIconStyle}" Content="✕" Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main Content Area ── -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          BorderThickness="0">
                <Grid Margin="32,48,32,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />   <!-- Page Title -->
                        <RowDefinition Height="Auto" />   <!-- Control Card -->
                        <RowDefinition Height="Auto" />   <!-- File List -->
                        <RowDefinition Height="Auto" />   <!-- Summary Banner -->
                        <RowDefinition Height="*" />      <!-- Results Area -->
                    </Grid.RowDefinitions>

                    <!-- ══ PAGE TITLE ══ -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,32">
                        <TextBlock x:Name="PageTitle" Text="Extraction" Style="{StaticResource TextPageTitle}" />
                        <!-- Geometric underline: small black square + horizontal line -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="6" Height="6"
                                    Background="{StaticResource BrushAccent}"
                                    CornerRadius="1"
                                    VerticalAlignment="Center" />
                            <Border Grid.Column="1"
                                    Height="1"
                                    Background="{StaticResource BrushBorder}"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <!-- ══ CONTROL CARD ══ -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <!-- Folder Picker -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Dossier source" Style="{StaticResource CardLabelStyle}" />
                                <DockPanel>
                                    <TextBox Text="{Binding SelectedFolder}"
                                             Style="{StaticResource TextBoxReadOnlyStyle}"
                                             ToolTip="Vous pouvez aussi glisser-déposer un dossier ici" />
                                    <Button x:Name="AddButton"
                                            Content="Ajouter"
                                            Style="{StaticResource ButtonPrimaryStyle}"
                                            Width="100"
                                            Margin="12,0,0,0"
                                            Click="AddButton_Click"
                                            ToolTip="Ajouter des factures (fichiers ou dossier)">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Ajouter des fichiers..." Command="{Binding BrowseFilesCommand}" />
                                                <MenuItem Header="Ajouter un dossier..."  Command="{Binding BrowseFolderCommand}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </DockPanel>
                            </StackPanel>

                            <!-- Engine Picker -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0">
                                <TextBlock Text="Moteur d'extraction" Style="{StaticResource CardLabelStyle}" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Style="{StaticResource ComboBoxStyle}"
                                              Width="180"
                                              SelectedValuePath="Tag"
                                              SelectedValue="{Binding SelectedEngine}">
                                        <ComboBoxItem Content="Automatique (Gemini → OCR)" Tag="auto" />
                                        <ComboBoxItem Content="Gemini Vision (cloud)" Tag="gemini">
                                            <ComboBoxItem.Style>
                                                <Style TargetType="ComboBoxItem">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding GeminiAvailable}" Value="False">
                                                            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                            <Setter Property="ToolTip" Value="Clé API Gemini non configurée" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBoxItem.Style>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="OCR local (PaddleOCR)" Tag="ocr" />
                                    </ComboBox>
                                    <Button Content="⚙"
                                            Style="{StaticResource ButtonIconStyle}"
                                            Margin="8,0,0,0"
                                            Command="{Binding ToggleSettingsCommand}"
                                            ToolTip="Configurer la clé API Gemini" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Run / Cancel -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="24,0">
                                <Button Style="{StaticResource ButtonPrimaryStyle}"
                                        Width="200"
                                        Command="{Binding StartExtractionCommand}"
                                        ToolTip="Lancer l'extraction (F5)">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Lancer l'extraction" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Width="200" Height="32"
                                        Margin="0,8,0,0"
                                        Command="{Binding CancelExtractionCommand}"
                                        ToolTip="Annuler l'extraction en cours (Échap)">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ButtonDangerStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExtracting}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="Annuler" VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>

                            <!-- Progress → Circular Ring -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="24,0,0,0" Orientation="Horizontal"
                                        Visibility="{Binding IsProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <controls:ProgressRing x:Name="ProgressRingControl"
                                                       Width="36" Height="36"
                                                       Percentage="{Binding ProgressPercentage}"
                                                       StrokeThickness="3"
                                                       TrackColor="{StaticResource BrushBorderLight}"
                                                       ProgressColor="{StaticResource BrushAccent}"
                                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ProgressText}"
                                           Style="{StaticResource TextMetadata}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══ FILE LIST CARD ══ -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyleCompact}" Margin="0,0,0,16"
                            Visibility="{Binding HasSelectedFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="{Binding FileCountLabel}"
                                           Style="{StaticResource TextCaption}"
                                           DockPanel.Dock="Left"
                                           VerticalAlignment="Center" />
                                <CheckBox Content="Tout sélectionner"
                                          Style="{StaticResource CheckBoxStyle}"
                                          IsChecked="{Binding AllFilesSelected}"
                                          Command="{Binding ToggleAllFilesCommand}"
                                          HorizontalAlignment="Right" />
                            </DockPanel>

                            <ItemsControl Grid.Row="1"
                                          ItemsSource="{Binding DetectedFiles}"
                                          MaxHeight="120">
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <WrapPanel IsItemsHost="True" />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding FileName}"
                                                  IsChecked="{Binding IsSelected}"
                                                  Style="{StaticResource CheckBoxStyle}"
                                                  Margin="0,2,24,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- ══ SUMMARY BANNER ══ -->
                    <Border Grid.Row="3" Margin="0,0,0,16"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="16,12"
                            Visibility="{Binding ShowSummaryBanner, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="{Binding SummaryBannerColor, Converter={StaticResource StringToColorBrushConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SummaryBannerText}"
                                       Foreground="{StaticResource BrushTextInverse}"
                                       FontWeight="{StaticResource FontWeightMedium}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="Relancer les erreurs"
                                    Style="{StaticResource ButtonSecondaryStyle}"
                                    Margin="16,0,0,0"
                                    Command="{Binding RerunAllErrorsCommand}"
                                    ToolTip="Relancer l'extraction uniquement pour les fichiers en erreur"
                                    Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <!-- ══ RESULTS AREA ══ -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="300">
                                <ColumnDefinition.Style>
                                    <Style TargetType="ColumnDefinition">
                                        <Setter Property="Width" Value="300" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedRow}" Value="False">
                                                <Setter Property="Width" Value="0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ColumnDefinition.Style>
                            </ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <!-- Results Card (Tabs + Grid) -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Tab Headers (custom, no TabControl) -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,16,24,0">
                                    <Border x:Name="TabResults"
                                            Padding="4,8"
                                            Margin="0,0,24,0"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="TabResults_Click">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Résultats"
                                                       Style="{StaticResource TextBody}"
                                                       x:Name="TabResultsText"
                                                       FontWeight="{StaticResource FontWeightMedium}" />
                                            <Border x:Name="TabResultsUnderline"
                                                    Height="2"
                                                    Background="{StaticResource BrushAccent}"
                                                    CornerRadius="1"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="TabIncomplete"
                                            Padding="4,8"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="TabIncomplete_Click">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Extractions Incomplètes"
                                                       Style="{StaticResource TextBody}"
                                                       x:Name="TabIncompleteText"
                                                       Foreground="{StaticResource BrushTextMuted}" />
                                            <Border x:Name="TabIncompleteUnderline"
                                                    Height="2"
                                                    Background="Transparent"
                                                    CornerRadius="1"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Tab Content: Results Grid -->
                                <Grid Grid.Row="1" x:Name="PanelResults" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Confidence Legend -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,8,24,12">
                                        <TextBlock Text="Confiance"
                                                   Style="{StaticResource TextMetadata}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0" />
                                        <Border Background="{StaticResource BrushConfidenceHigh}"
                                                CornerRadius="4" Padding="8,2" Margin="0,0,8,0">
                                            <TextBlock Text="Élevée (≥75%)" Foreground="{StaticResource BrushTextInverse}"
                                                       FontSize="11" FontWeight="{StaticResource FontWeightMedium}" />
                                        </Border>
                                        <Border Background="{StaticResource BrushConfidenceMedium}"
                                                CornerRadius="4" Padding="8,2" Margin="0,0,8,0">
                                            <TextBlock Text="Moyenne (40-75%)" Foreground="{StaticResource BrushTextInverse}"
                                                       FontSize="11" FontWeight="{StaticResource FontWeightMedium}" />
                                        </Border>
                                        <Border Background="{StaticResource BrushConfidenceLow}"
                                                CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="Basse (&lt;40%)" Foreground="{StaticResource BrushTextInverse}"
                                                       FontSize="11" FontWeight="{StaticResource FontWeightMedium}" />
                                        </Border>
                                    </StackPanel>

                                    <DataGrid Grid.Row="1"
                                              x:Name="ResultsGrid"
                                              ItemsSource="{Binding Results}"
                                              Style="{StaticResource ResultGridStyle}"
                                              SelectedItem="{Binding SelectedRow}"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              EnableRowVirtualization="True"
                                              LoadingRow="ResultsGrid_LoadingRow">
                                        <DataGrid.Resources>
                                            <ContextMenu x:Key="RowContextMenu">
                                                <MenuItem Header="Relancer l'extraction" Command="{Binding DataContext.RerunCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <!-- Select Checkbox -->
                                            <DataGridTemplateColumn Width="44" CanUserSort="False">
                                                <DataGridTemplateColumn.HeaderTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding DataContext.AllRowsSelected, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Command="{Binding DataContext.ToggleAllRowsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.HeaderTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="N° Facture" Binding="{Binding NumeroFacture, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="100" MaxWidth="180">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Padding" Value="16,14" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding NumeroFactureMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Date" Binding="{Binding Date, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="80" MaxWidth="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DateMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Fournisseur" Binding="{Binding Fournisseur, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="100" MaxWidth="200">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FournisseurMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Client" Binding="{Binding Client, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="80" MaxWidth="160">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ClientMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="Montant HT" Binding="{Binding MontantHt, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="80" MaxWidth="120" />

                                            <DataGridTextColumn Header="TVA" Binding="{Binding MontantTva, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="60" MaxWidth="100" />

                                            <DataGridTextColumn Header="Taxe" Binding="{Binding MontantTaxe, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="60" MaxWidth="100" />

                                            <DataGridTextColumn Header="TTC" Binding="{Binding MontantTtc, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="60" MaxWidth="100" />

                                            <!-- Confidence Badge -->
                                            <DataGridTemplateColumn Header="Confiance" Width="160" CanUserSort="True" SortMemberPath="Confidence">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                            <Border Background="{Binding Confidence, Converter={StaticResource ConfidenceToColorConverter}}"
                                                                    CornerRadius="6" Padding="10,4"
                                                                    ToolTip="{Binding ConfidenceTooltip}">
                                                                <TextBlock Text="{Binding ConfidenceDisplay}"
                                                                           Foreground="{StaticResource BrushTextInverse}"
                                                                           FontWeight="{StaticResource FontWeightMedium}"
                                                                           FontSize="12" />
                                                            </Border>
                                                            <Border Style="{StaticResource EngineBadgeStyle}"
                                                                    Margin="8,0,0,0"
                                                                    Visibility="{Binding IsLocalOcr, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="Local (hors ligne)"
                                                                           Foreground="{StaticResource BrushTextMuted}"
                                                                           FontSize="10" />
                                                            </Border>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Fichier" Binding="{Binding FileDisplay}" MinWidth="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Empty State Overlay -->
                                    <Border Grid.Row="1" Background="Transparent" Visibility="Collapsed">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Results.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- Geometric artwork for empty state -->
                                            <Grid Width="120" Height="100" Margin="0,0,0,24">
                                                <Border Width="60" Height="60"
                                                        Background="{StaticResource BrushGeometricFill}"
                                                        CornerRadius="4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top" />
                                                <Border Width="40" Height="40"
                                                        Background="{StaticResource BrushAccent}"
                                                        CornerRadius="4"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom" />
                                                <Border Width="80" Height="2"
                                                        Background="{StaticResource BrushBorder}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Text="Aucune facture traitée"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Sélectionnez un dossier et lancez l'extraction"
                                                       Style="{StaticResource TextCaption}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Tab Content: Incomplete Grid (hidden by default) -->
                                <Grid Grid.Row="1" x:Name="PanelIncomplete" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Ces factures nécessitent une vérification manuelle"
                                               Style="{StaticResource TextCaption}"
                                               Foreground="{StaticResource BrushAccent}"
                                               Margin="24,8,24,12" />

                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding IncompleteResults}"
                                              Style="{StaticResource ResultGridStyle}"
                                              SelectedItem="{Binding SelectedRow}">
                                        <DataGrid.Resources>
                                            <ContextMenu x:Key="RowContextMenu">
                                                <MenuItem Header="Relancer l'extraction" Command="{Binding DataContext.RerunCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="44" CanUserSort="False">
                                                <DataGridTemplateColumn.HeaderTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding DataContext.AllRowsSelected, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Command="{Binding DataContext.ToggleAllRowsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.HeaderTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="N° Facture" Binding="{Binding NumeroFacture, Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="100" MaxWidth="180" />
                                            <DataGridTextColumn Header="Date"        Binding="{Binding Date,          Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="80"  MaxWidth="120" />
                                            <DataGridTextColumn Header="Fournisseur" Binding="{Binding Fournisseur,   Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="100" MaxWidth="200" />
                                            <DataGridTextColumn Header="Client"      Binding="{Binding Client,        Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="80"  MaxWidth="160" />
                                            <DataGridTextColumn Header="Montant HT"  Binding="{Binding MontantHt,     Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="80"  MaxWidth="120" />
                                            <DataGridTextColumn Header="TVA"         Binding="{Binding MontantTva,    Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="60"  MaxWidth="100" />
                                            <DataGridTextColumn Header="Taxe"        Binding="{Binding MontantTaxe,   Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="60"  MaxWidth="100" />
                                            <DataGridTextColumn Header="TTC"         Binding="{Binding MontantTtc,    Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="60"  MaxWidth="100" />

                                            <DataGridTemplateColumn Header="Confiance" Width="160" CanUserSort="True" SortMemberPath="Confidence">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                            <Border Background="{Binding Confidence, Converter={StaticResource ConfidenceToColorConverter}}"
                                                                    CornerRadius="6" Padding="10,4"
                                                                    ToolTip="{Binding ConfidenceTooltip}">
                                                                <TextBlock Text="{Binding ConfidenceDisplay}"
                                                                           Foreground="{StaticResource BrushTextInverse}"
                                                                           FontWeight="{StaticResource FontWeightMedium}"
                                                                           FontSize="12" />
                                                            </Border>
                                                            <Border Style="{StaticResource EngineBadgeStyle}"
                                                                    Margin="8,0,0,0"
                                                                    Visibility="{Binding IsLocalOcr, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="Local (hors ligne)"
                                                                           Foreground="{StaticResource BrushTextMuted}"
                                                                           FontSize="10" />
                                                            </Border>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Fichier" Binding="{Binding FileDisplay}" MinWidth="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                                    <!-- Empty State -->
                                    <Border Grid.Row="1" Background="Transparent" Visibility="Collapsed">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IncompleteResults.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="40" Height="40"
                                                    Background="{StaticResource BrushGeometricFill}"
                                                    CornerRadius="20"
                                                    Margin="0,0,0,16" />
                                            <TextBlock Text="Aucune extraction incomplète"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1"
                                      Width="4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="{StaticResource BrushBorderLight}"
                                      Cursor="SizeWE"
                                      Visibility="{Binding HasSelectedRow, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!-- Raw Text Preview Card -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}"
                                Padding="16"
                                Visibility="{Binding HasSelectedRow, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource ButtonIconStyle}"
                                            Content="✕"
                                            Width="24" Height="24"
                                            Command="{Binding ClearSelectedRowCommand}" />
                                    <TextBlock Text="{Binding PreviewFileName}"
                                               Style="{StaticResource TextCaption}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding PreviewRawText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             Style="{StaticResource TextBoxReadOnlyStyle}"
                                             Background="{StaticResource BrushAltBackground}"
                                             BorderThickness="0"
                                             FontFamily="{StaticResource FontMono}"
                                             FontSize="{StaticResource FontSizeCaption}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- ══ STATUS BAR ══ -->
            <Border Grid.Row="2"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BrushBorderLight}"
                    Background="{StaticResource BrushBackground}">
                <Grid Margin="32,0,32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SummaryText}" Style="{StaticResource TextMetadata}" />

                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding ShowSaveConfirmation, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding SaveConfirmationText}"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource BrushSuccess}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="Ouvrir le dossier"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource BrushAccent}"
                                       Cursor="Hand"
                                       TextDecorations="Underline"
                                       VerticalAlignment="Center">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSavedFolderCommand}" />
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Exporter en Excel"
                                Style="{StaticResource ButtonPrimaryStyle}"
                                Margin="0,0,12,0"
                                Command="{Binding ExportExcelCommand}"
                                ToolTip="Exporter les résultats vers Excel (Ctrl+E)" />
                        <Button Content="Effacer"
                                Style="{StaticResource ButtonSecondaryStyle}"
                                Command="{Binding ClearCommand}"
                                ToolTip="Effacer tous les résultats" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ SERVER DIED OVERLAY ══ -->
        <Border Grid.ColumnSpan="2"
                Background="{StaticResource BrushOverlay}"
                Panel.ZIndex="1000"
                Visibility="{Binding IsServerRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border Style="{StaticResource DialogStyle}"
                    Width="440"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Geometric composition -->
                    <Grid Width="48" Height="48" Margin="0,0,0,24">
                        <Border Width="48" Height="48"
                                Background="{StaticResource BrushAccentLight}"
                                CornerRadius="12" />
                        <Border Width="16" Height="16"
                                Background="{StaticResource BrushAccent}"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="Le serveur OCR s'est arrêté"
                               Style="{StaticResource TextSectionHeading}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Veuillez redémarrer l'application pour continuer."
                               Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,32" />
                    <Button Content="Fermer l'application"
                            Style="{StaticResource ButtonPrimaryStyle}"
                            Width="200"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

<Window x:Class="Hotix.InvoiceClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:Hotix.InvoiceClient.Controls"
        xmlns:ui="clr-namespace:Hotix.InvoiceClient"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="{Binding WindowTitle}"
        Icon="pack://application:,,,/hotix_icon.ico"
        Width="1280"
        Height="820"
        MinWidth="1000"
        MinHeight="700"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        WindowState="Maximized"
        Background="{StaticResource BrushBackground}"
        Foreground="{StaticResource BrushTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        FontSize="{StaticResource FontSizeBody}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        AllowDrop="True"
        UseLayoutRounding="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <!-- WindowChrome for native resize behavior -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="F5"     Command="{Binding StartExtractionCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelExtractionCommand}" />
        <KeyBinding Key="E"      Modifiers="Ctrl" Command="{Binding ExportExcelCommand}" />
    </Window.InputBindings>

    <!-- Window Fade-In on Load (targets root Grid opacity via storyboard) -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource StoryboardWindowFadeIn}" />
        </EventTrigger>
    </Window.Triggers>

    <!-- ══ ROOT GRID: Sidebar | Main ══ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════
             SIDEBAR
             ═══════════════════════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource SidebarStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />   <!-- Logo -->
                    <RowDefinition Height="*" />       <!-- Navigation -->
                    <RowDefinition Height="Auto" />    <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- ── Logo Area ── -->
                <StackPanel Grid.Row="0" Margin="24,32,24,40">
                    <Border Width="36" Height="36"
                            Background="{StaticResource BrushAccent}"
                            CornerRadius="10"
                            Margin="0,0,0,16">
                        <TextBlock Text="H"
                                   FontSize="18"
                                   FontWeight="700"
                                   Foreground="{StaticResource BrushTextInverse}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="HOTIX" Style="{StaticResource SidebarLogoStyle}" />
                </StackPanel>

                <!-- ── Navigation ── -->
                <StackPanel Grid.Row="1" Margin="12,0,12,0">
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[SidebarNavigation]}" Style="{StaticResource SidebarSectionLabel}" />

                    <!-- Extraction Nav Item (selected by default) -->
                    <Border x:Name="NavExtraction" Style="{StaticResource NavItemStyleActive}" MouseLeftButtonDown="NavExtraction_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <TextBlock Grid.Column="0" x:Name="NavExtractionIcon" Text="◇" Style="{StaticResource NavIconActiveStyle}" />

                            <!-- Text -->
                            <TextBlock Grid.Column="1" x:Name="NavExtractionText"
                                       Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[SidebarExtraction]}" Style="{StaticResource NavTextSelectedStyle}" />
                        </Grid>
                    </Border>

                    <!-- About Nav Item -->
                    <Border x:Name="NavAbout" Style="{StaticResource NavItemStyle}" MouseLeftButtonDown="NavAbout_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" x:Name="NavAboutIcon" Text="○" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Grid.Column="1" x:Name="NavAboutText"
                                       Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[SidebarAbout]}" Style="{StaticResource NavTextStyle}" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Footer ── -->
                <StackPanel Grid.Row="2" Margin="24,0,24,24">
                    <!-- Server status indicator -->
                    <DockPanel Margin="0,0,0,12"
                               ToolTip="{Binding ServerStatusTooltip}">
                        <Border Width="6" Height="6"
                                CornerRadius="3"
                                VerticalAlignment="Center"
                                Background="{Binding ServerStatusDotColor, Converter={StaticResource StringToColorBrushConverter}}"
                                DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding ServerStatusText}"
                                   Style="{StaticResource TextTiny}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[SidebarVersion]}" Style="{StaticResource SidebarFooterStyle}" />
                    <TextBlock Text="HOTIX" Style="{StaticResource SidebarFooterStyle}" Margin="0,2,0,0" />

                    <!-- Language selector -->
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[LangLabel]}"
                                   Style="{StaticResource TextTiny}"
                                   Margin="0,0,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="LangFrenchRadio"
                                         Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[LangFrench]}"
                                         GroupName="Language"
                                         Style="{StaticResource RadioButtonStyle}"
                                         Margin="0,0,12,0"
                                         Checked="LangFrench_Checked" />
                            <RadioButton x:Name="LangEnglishRadio"
                                         Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[LangEnglish]}"
                                         GroupName="Language"
                                         Style="{StaticResource RadioButtonStyle}"
                                         Checked="LangEnglish_Checked" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════
             MAIN WORKSPACE
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{StaticResource BrushAltBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />   <!-- Title Bar -->
                <RowDefinition Height="*" />     <!-- Content -->
                <RowDefinition Height="44" />    <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- ── Custom Title Bar ── -->
            <Border Grid.Row="0"
                    BorderThickness="0,0,0,0"
                    Background="{StaticResource BrushBackground}">
                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Style="{StaticResource TextCaption}"
                               Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[MainWindowTitle]}"
                               VerticalAlignment="Center"
                               Margin="32,0,0,0" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Button Style="{StaticResource ButtonIconStyle}" Content="─" Click="MinimizeButton_Click" />
                        <Button Style="{StaticResource ButtonIconStyle}" Content="□" Click="MaximizeButton_Click" />
                        <Button Style="{StaticResource ButtonIconStyle}" Content="✕" Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main Content Area ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          PanningDeceleration="0.003"
                          BorderThickness="0">
                <Grid x:Name="MainContentGrid" Margin="40,40,40,32" HorizontalAlignment="Stretch" MaxWidth="1400" MinWidth="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />   <!-- Page Title -->
                        <RowDefinition Height="Auto" />   <!-- Step 1: Source Card -->
                        <RowDefinition Height="Auto" />   <!-- Step 2: File List -->
                        <RowDefinition Height="Auto" />   <!-- Progress -->
                        <RowDefinition Height="Auto" />   <!-- Notification -->
                        <RowDefinition Height="*" />      <!-- Step 3: Results -->
                    </Grid.RowDefinitions>

                    <!-- ══ PAGE TITLE ══ -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,32" MaxWidth="800">
                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[EmptyResultsDesc]}"
                                   Style="{StaticResource TextBody}"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                    </StackPanel>

                    <!-- ══ STEP 1: SOURCE FOLDER + ENGINE ══ -->
                    <Border x:Name="StepOneCard" Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Step label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="24" Height="24" CornerRadius="{StaticResource RadiusSmall}"
                                        Background="{StaticResource BrushAccentLight}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="1" FontSize="12" FontWeight="{StaticResource FontWeightMedium}"
                                               Foreground="{StaticResource BrushAccent}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlSourceFolder]}"
                                           Style="{StaticResource TextCardTitle}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Folder input + Browse -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                    <Button x:Name="AddButton"
                                            Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlAddBtn]}"
                                            Style="{StaticResource ButtonPrimaryStyle}"
                                            MinWidth="80"
                                            Margin="12,0,0,0"
                                            DockPanel.Dock="Right"
                                            Click="AddButton_Click"
                                            ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlAddTooltip]}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlAddFiles]}" Command="{Binding BrowseFilesCommand}" />
                                                <MenuItem Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlAddFolder]}"  Command="{Binding BrowseFolderCommand}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                    <TextBox Text="{Binding SelectedFolder}"
                                             Style="{StaticResource TextBoxReadOnlyStyle}"
                                             ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlDropTooltip]}" />
                                </DockPanel>

                                <!-- Engine picker + Run button row -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Info + Label (Column 0, Auto) -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="InfoEngineIcon"
                                                   Text="ⓘ"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"
                                                   Cursor="Hand"
                                                   MouseLeftButtonDown="InfoButton_Click" />
                                        <Popup x:Name="InfoEnginePopup"
                                               PlacementTarget="{Binding ElementName=InfoEngineIcon}"
                                               Placement="Bottom"
                                               AllowsTransparency="True"
                                               StaysOpen="False"
                                               PopupAnimation="Fade">
                                            <Border Background="{StaticResource BrushSurface}"
                                                    BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="14,10"
                                                    MaxWidth="300"
                                                    Effect="{StaticResource ShadowCard}">
                                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[InfoEngine]}"
                                                           Style="{StaticResource TextCaption}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </Popup>
                                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlEngineLabel]}"
                                                   Style="{StaticResource CardLabelStyle}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- ComboBox + Settings (Column 1, *) -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <ComboBox x:Name="EngineCombo"
                                                  Style="{StaticResource ComboBoxStyle}"
                                                  MinWidth="200"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="{Binding SelectedEngine}"
                                                  ToolTip="{Binding ResolvedEngineDisplay}">
                                            <ComboBoxItem Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlEngineAuto]}" Tag="auto" />
                                            <ComboBoxItem Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlEngineGemini]}" Tag="gemini">
                                                <ComboBoxItem.Style>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding GeminiAvailable}" Value="False">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="ToolTip" Value="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlEngineNoKey], Mode=OneWay}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBoxItem.Style>
                                            </ComboBoxItem>
                                            <ComboBoxItem Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlEngineGrok]}" Tag="grok">
                                                <ComboBoxItem.Style>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding GrokAvailable}" Value="False">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="ToolTip" Value="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlEngineNoKey], Mode=OneWay}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBoxItem.Style>
                                            </ComboBoxItem>
                                            <ComboBoxItem Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlEngineOcr]}" Tag="ocr" />
                                        </ComboBox>
                                        <Button Content="⚙"
                                                Style="{StaticResource ButtonIconStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding ToggleSettingsCommand}"
                                                ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlSettingsTooltip]}" />
                                    </StackPanel>

                                    <!-- Run button -->
                                    <Button x:Name="RunButton"
                                            Grid.Column="2"
                                            Style="{StaticResource ButtonPrimaryStyle}"
                                            MinWidth="130"
                                            Padding="24,10"
                                            Margin="24,0,8,0"
                                            Command="{Binding StartExtractionCommand}"
                                            ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlRunTooltip]}">
                                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlRunBtn]}" VerticalAlignment="Center" />
                                    </Button>

                                    <!-- Cancel button -->
                                    <Button Grid.Column="3"
                                            MinWidth="90"
                                            Command="{Binding CancelExtractionCommand}"
                                            ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlCancelTooltip]}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ButtonDangerStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExtracting}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlCancelBtn]}" VerticalAlignment="Center" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ══ STEP 2: DETECTED FILES ══ -->
                    <Border x:Name="StepTwoCard" Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,12"
                            Visibility="{Binding HasSelectedFolder, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Step label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="24" Height="24" CornerRadius="{StaticResource RadiusSmall}"
                                        Background="{StaticResource BrushAccentLight}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="2" FontSize="12" FontWeight="{StaticResource FontWeightMedium}"
                                               Foreground="{StaticResource BrushAccent}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[TabResults]}"
                                           Style="{StaticResource TextCardTitle}"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding FileCountLabel}"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                                <CheckBox Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ControlSelectAll]}"
                                          Style="{StaticResource CheckBoxStyle}"
                                          IsChecked="{Binding AllFilesSelected}"
                                          Command="{Binding ToggleAllFilesCommand}"
                                          Margin="16,0,0,0" />
                            </StackPanel>

                            <!-- File cards -->
                            <ItemsControl Grid.Row="1"                                                            ItemsSource="{Binding DetectedFiles}"
                                          MaxHeight="240">
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                                      BorderThickness="0"
                                                      Background="Transparent">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="{StaticResource RadiusSmall}"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                Padding="12,10"
                                                Margin="0,0,0,6"
                                                Background="{StaticResource BrushSurface}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelected}"
                                                          Style="{StaticResource CheckBoxStyle}"
                                                          VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               Style="{StaticResource TextBody}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding FileSizeDisplay}"
                                                               Style="{StaticResource TextTiny}"
                                                               Foreground="{StaticResource BrushTextMuted}"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                                <Border Grid.Column="2"
                                                        CornerRadius="{StaticResource RadiusPill}"
                                                        Background="{StaticResource BrushConfidenceHighBg}"
                                                        Padding="8,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Style="{StaticResource TextTiny}"
                                                               Foreground="{StaticResource BrushConfidenceHighText}">
                                                        <Run Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[FileReady], Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- ══ PROGRESS SECTION ══ -->
                    <Border Grid.Row="3" Style="{StaticResource CardStyleCompact}" Margin="0,0,0,12"
                            Visibility="{Binding IsProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,0">
                                <controls:ProgressRing x:Name="ProgressRingControl"
                                                       Width="32" Height="32"
                                                       Percentage="{Binding ProgressPercentage, Mode=OneWay}"
                                                       StrokeThickness="3"
                                                       TrackColor="{StaticResource BrushBorderLight}"
                                                       ProgressColor="{StaticResource BrushAccent}" />
                                <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock Style="{StaticResource TextBody}"
                                               FontWeight="{StaticResource FontWeightMedium}">
                                        <Run Text="{Binding ProgressPercentage, Mode=OneWay, StringFormat={}{0:F0}%}" />
                                        <Run Text="—" />
                                        <Run Text="{Binding ExtractionStatusText, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding ProgressText}"
                                               Style="{StaticResource TextCaption}"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══ NOTIFICATION CARD ══ -->
                    <Border Grid.Row="4"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Padding="16,14"
                            Margin="0,0,0,12"
                            BorderThickness="1"
                            Visibility="{Binding ShowSummaryBanner, Converter={StaticResource BooleanToVisibilityConverter}}"
                            BorderBrush="{StaticResource BrushBorder}"
                            Background="{StaticResource BrushSurface}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Status icon (colored dot) -->
                            <Border Grid.Column="0"
                                    Width="10" Height="10"
                                    CornerRadius="5"
                                    VerticalAlignment="Top"
                                    Margin="0,5,12,0"
                                    Background="{Binding SummaryBannerColor, Converter={StaticResource StringToColorBrushConverter}}" />

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SummaryBannerText}"
                                           Style="{StaticResource TextBody}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BtnRerunErrors]}"
                                    Style="{StaticResource ButtonDangerStyle}"
                                    Margin="16,0,0,0"
                                    Command="{Binding RerunAllErrorsCommand}"
                                    ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BtnRerunErrorsTooltip]}"
                                    Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <!-- ══ STEP 3: RESULTS AREA ══ -->
                    <Grid x:Name="ResultsSection" Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="300">
                                <ColumnDefinition.Style>
                                    <Style TargetType="ColumnDefinition">
                                        <Setter Property="Width" Value="300" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedRow}" Value="False">
                                                <Setter Property="Width" Value="0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ColumnDefinition.Style>
                            </ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <!-- Results Card (Tabs + Grid) -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Tab Headers (custom, no TabControl) -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,16,24,0">
                                    <Border x:Name="TabResults"
                                            Padding="4,8"
                                            Margin="0,0,24,0"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="TabResults_Click">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[TabResults]}"
                                                       Style="{StaticResource TextBody}"
                                                       x:Name="TabResultsText"
                                                       FontWeight="{StaticResource FontWeightMedium}" />
                                            <Border x:Name="TabResultsUnderline"
                                                    Height="2"
                                                    Background="{StaticResource BrushAccent}"
                                                    CornerRadius="1"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="TabIncomplete"
                                            Padding="4,8"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="TabIncomplete_Click">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[TabIncomplete]}"
                                                       Style="{StaticResource TextBody}"
                                                       x:Name="TabIncompleteText"
                                                       Foreground="{StaticResource BrushTextMuted}" />
                                            <Border x:Name="TabIncompleteUnderline"
                                                    Height="2"
                                                    Background="Transparent"
                                                    CornerRadius="1"
                                                    Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Tab Content: Results Grid -->
                                <Grid Grid.Row="1" x:Name="PanelResults" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Confidence Legend (pastel badges) -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,8,24,12">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="InfoConfidenceIcon"
                                                       Text="ⓘ"
                                                       FontSize="12"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"
                                                       Cursor="Hand"
                                                       MouseLeftButtonDown="InfoButton_Click" />
                                            <Popup x:Name="InfoConfidencePopup"
                                                   PlacementTarget="{Binding ElementName=InfoConfidenceIcon}"
                                                   Placement="Bottom"
                                                   AllowsTransparency="True"
                                                   StaysOpen="False"
                                                   PopupAnimation="Fade">
                                                <Border Background="{StaticResource BrushSurface}"
                                                        BorderBrush="{StaticResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="14,10"
                                                        MaxWidth="300"
                                                        Effect="{StaticResource ShadowCard}">
                                                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[InfoConfidence]}"
                                                               Style="{StaticResource TextCaption}"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </Popup>
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[LegendConfidence]}"
                                                       Style="{StaticResource TextMetadata}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0" />
                                        </StackPanel>
                                        <Border Background="{StaticResource BrushConfidenceHighBg}"
                                                CornerRadius="{StaticResource RadiusPill}" Padding="10,4" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[LegendHigh]}" Foreground="{StaticResource BrushConfidenceHighText}"
                                                       FontSize="{StaticResource FontSizeCaption}" FontWeight="{StaticResource FontWeightMedium}" />
                                        </Border>
                                        <Border Background="{StaticResource BrushConfidenceMediumBg}"
                                                CornerRadius="{StaticResource RadiusPill}" Padding="10,4" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[LegendMedium]}" Foreground="{StaticResource BrushConfidenceMediumText}"
                                                       FontSize="{StaticResource FontSizeCaption}" FontWeight="{StaticResource FontWeightMedium}" />
                                        </Border>
                                        <Border Background="{StaticResource BrushConfidenceLowBg}"
                                                CornerRadius="{StaticResource RadiusPill}" Padding="10,4">
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[LegendLow]}" Foreground="{StaticResource BrushConfidenceLowText}"
                                                       FontSize="{StaticResource FontSizeCaption}" FontWeight="{StaticResource FontWeightMedium}" />
                                        </Border>
                                    </StackPanel>

                                    <DataGrid Grid.Row="1"
                                              x:Name="ResultsGrid"
                                              ItemsSource="{Binding Results}"
                                              Style="{StaticResource ResultGridStyle}"
                                              SelectedItem="{Binding SelectedRow}"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              EnableRowVirtualization="True"
                                              LoadingRow="ResultsGrid_LoadingRow">
                                        <DataGrid.Resources>
                                            <ContextMenu x:Key="RowContextMenu">
                                                <MenuItem Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ContextMenuRerun]}" Command="{Binding DataContext.RerunCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </DataGrid.Resources>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                                                <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <!-- Select Checkbox -->
                                            <DataGridTemplateColumn Width="44" CanUserSort="False">
                                                <DataGridTemplateColumn.HeaderTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding DataContext.AllRowsSelected, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Command="{Binding DataContext.ToggleAllRowsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.HeaderTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnInvoiceNo]}" Binding="{Binding NumeroFacture, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="100" MaxWidth="180">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="Padding" Value="16,14" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding NumeroFactureMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnDate]}" Binding="{Binding Date, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="80" MaxWidth="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DateMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnSupplier]}" Binding="{Binding Fournisseur, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="100" MaxWidth="200">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FournisseurMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnClient]}" Binding="{Binding Client, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="80" MaxWidth="160">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ClientMissing}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                                                                <Setter Property="FontStyle" Value="Italic" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnAmountExcl]}"  Binding="{Binding MontantHt, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="80" MaxWidth="120" />

                                            <DataGridTextColumn Header="TVA" Binding="{Binding MontantTva, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="60" MaxWidth="100" />

                                            <DataGridTextColumn Header="Taxe" Binding="{Binding MontantTaxe, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="60" MaxWidth="100" />

                                            <DataGridTextColumn Header="TTC" Binding="{Binding MontantTtc, Converter={StaticResource NullToPlaceholderConverter}}"
                                                                MinWidth="60" MaxWidth="100" />

                                            <!-- Confidence Badge (pastel) -->
                                            <DataGridTemplateColumn Header="Confiance" Width="160" CanUserSort="True" SortMemberPath="Confidence">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                            <Border CornerRadius="{StaticResource RadiusPill}" Padding="10,4"
                                                                    ToolTip="{Binding ConfidenceTooltip}"
                                                                    Background="{Binding Confidence, Converter={StaticResource ConfidenceToColorConverter}}">
                                                                <TextBlock Text="{Binding ConfidenceDisplay}"
                                                                           FontWeight="{StaticResource FontWeightMedium}"
                                                                           FontSize="{StaticResource FontSizeCaption}" />
                                                            </Border>
                                                            <Border Style="{StaticResource EngineBadgeStyle}"
                                                                    Margin="8,0,0,0"
                                                                    Visibility="{Binding IsLocalOcr, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BadgeLocalOcr]}"
                                                                           Foreground="{StaticResource BrushTextMuted}"
                                                                           FontSize="10" />
                                                            </Border>
                                                            <!-- Fallback warning icon -->
                                                            <Border CornerRadius="{StaticResource RadiusPill}"
                                                                    Padding="6,2"
                                                                    Margin="4,0,0,0"
                                                                    Background="{StaticResource BrushWarning}"
                                                                    Visibility="{Binding HasGeminiFallback, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    ToolTip="{Binding GeminiFallbackReason}">
                                                                <TextBlock Text="⚠"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource BrushTextInverse}" />
                                                            </Border>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnFile]}" Binding="{Binding FileDisplay, Mode=OneWay}" MinWidth="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Empty State Overlay -->
                                    <Border Grid.Row="1" Background="Transparent" Visibility="Collapsed">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Results.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- Geometric artwork for empty state -->
                                            <Grid Width="120" Height="100" Margin="0,0,0,24">
                                                <Border Width="60" Height="60"
                                                        Background="{StaticResource BrushGeometricFill}"
                                                        CornerRadius="4"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top" />
                                                <Border Width="40" Height="40"
                                                        Background="{StaticResource BrushAccent}"
                                                        CornerRadius="4"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom" />
                                                <Border Width="80" Height="2"
                                                        Background="{StaticResource BrushBorder}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[EmptyResultsTitle]}"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[EmptyResultsDesc]}"
                                                       Style="{StaticResource TextCaption}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Tab Content: Incomplete Grid (hidden by default) -->
                                <Grid Grid.Row="1" x:Name="PanelIncomplete" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,8,24,12">
                                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[TabIncomplete]}"
                                                   Style="{StaticResource TextBody}"
                                                   Foreground="{StaticResource BrushAccent}" />
                                        <Grid>
                                            <TextBlock x:Name="InfoIncompleteIcon"
                                                       Text="ⓘ"
                                                       FontSize="12"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0"
                                                       Cursor="Hand"
                                                       MouseLeftButtonDown="InfoButton_Click" />
                                            <Popup x:Name="InfoIncompletePopup"
                                                   PlacementTarget="{Binding ElementName=InfoIncompleteIcon}"
                                                   Placement="Bottom"
                                                   AllowsTransparency="True"
                                                   StaysOpen="False"
                                                   PopupAnimation="Fade">
                                                <Border Background="{StaticResource BrushSurface}"
                                                        BorderBrush="{StaticResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="14,10"
                                                        MaxWidth="300"
                                                        Effect="{StaticResource ShadowCard}">
                                                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[InfoIncomplete]}"
                                                               Style="{StaticResource TextCaption}"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </StackPanel>

                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding IncompleteResults}"
                                              Style="{StaticResource ResultGridStyle}"
                                              SelectedItem="{Binding SelectedRow}">
                                        <DataGrid.Resources>
                                            <ContextMenu x:Key="RowContextMenu">
                                                <MenuItem Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ContextMenuRerun]}" Command="{Binding DataContext.RerunCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </DataGrid.Resources>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                                                <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}" />
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="44" CanUserSort="False">
                                                <DataGridTemplateColumn.HeaderTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding DataContext.AllRowsSelected, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Command="{Binding DataContext.ToggleAllRowsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.HeaderTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                                  Style="{StaticResource CheckBoxStyle}" HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnInvoiceNo]}" Binding="{Binding NumeroFacture, Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="100" MaxWidth="180" />                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnDate]}" Binding="{Binding Date, Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="80"  MaxWidth="120" />
                                            <DataGridTextColumn Header="Fournisseur" Binding="{Binding Fournisseur,   Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="100" MaxWidth="200" />
                                            <DataGridTextColumn Header="Client"      Binding="{Binding Client,        Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="80"  MaxWidth="160" />
                                            <DataGridTextColumn Header="Montant HT"  Binding="{Binding MontantHt,     Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="80"  MaxWidth="120" />
                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnVat]}"         Binding="{Binding MontantTva,    Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="60"  MaxWidth="100" />
                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnTax]}"        Binding="{Binding MontantTaxe,   Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="60"  MaxWidth="100" />
                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnTotalIncl]}"         Binding="{Binding MontantTtc,    Converter={StaticResource NullToPlaceholderConverter}}" MinWidth="60"  MaxWidth="100" />

                                            <DataGridTemplateColumn Header="Confiance" Width="160" CanUserSort="True" SortMemberPath="Confidence">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                            <Border CornerRadius="{StaticResource RadiusPill}" Padding="10,4"
                                                                    ToolTip="{Binding ConfidenceTooltip}"
                                                                    Background="{Binding Confidence, Converter={StaticResource ConfidenceToColorConverter}}">
                                                                <TextBlock Text="{Binding ConfidenceDisplay}"
                                                                           FontWeight="{StaticResource FontWeightMedium}"
                                                                           FontSize="{StaticResource FontSizeCaption}" />
                                                            </Border>
                                                            <Border Style="{StaticResource EngineBadgeStyle}"
                                                                    Margin="8,0,0,0"
                                                                    Visibility="{Binding IsLocalOcr, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BadgeLocalOcr]}"
                                                                           Foreground="{StaticResource BrushTextMuted}"
                                                                           FontSize="10" />
                                                            </Border>
                                                            <!-- Fallback warning icon -->
                                                            <Border CornerRadius="{StaticResource RadiusPill}"
                                                                    Padding="6,2"
                                                                    Margin="4,0,0,0"
                                                                    Background="{StaticResource BrushWarning}"
                                                                    Visibility="{Binding HasGeminiFallback, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    ToolTip="{Binding GeminiFallbackReason}">
                                                                <TextBlock Text="⚠"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource BrushTextInverse}" />
                                                            </Border>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ColumnFile]}" Binding="{Binding FileDisplay, Mode=OneWay}" MinWidth="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                                    <!-- Empty State -->
                                    <Border Grid.Row="1" Background="Transparent" Visibility="Collapsed">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IncompleteResults.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="40" Height="40"
                                                    Background="{StaticResource BrushGeometricFill}"
                                                    CornerRadius="20"
                                                    Margin="0,0,0,16" />
                                            <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[EmptyIncompleteTitle]}"
                                                       Style="{StaticResource TextBody}"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1"
                                      Width="4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Stretch"
                                      Background="{StaticResource BrushBorderLight}"
                                      Cursor="SizeWE"
                                      Visibility="{Binding HasSelectedRow, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <!-- Raw Text Preview Card -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}"
                                Padding="16"
                                Visibility="{Binding HasSelectedRow, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource ButtonIconStyle}"
                                            Content="✕"
                                            Width="24" Height="24"
                                            Command="{Binding ClearSelectedRowCommand}" />
                                    <TextBlock Text="{Binding PreviewFileName}"
                                               Style="{StaticResource TextCaption}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding PreviewRawText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             Style="{StaticResource TextBoxReadOnlyStyle}"
                                             Background="{StaticResource BrushAltBackground}"
                                             BorderThickness="0"
                                             FontFamily="{StaticResource FontMono}"
                                             FontSize="{StaticResource FontSizeCaption}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- ══ EXPORT TOOLBAR ══ -->
            <Border Grid.Row="2"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BrushBorderLight}"
                    Background="{StaticResource BrushSurface}">
                <Grid Margin="32,0,32,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Summary stats -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SummaryText}" Style="{StaticResource TextCaption}"
                                   VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}" />

                        <!-- Server starting status -->
                        <TextBlock Text="{Binding ServerStartingStatus}"
                                   Style="{StaticResource TextCaption}"
                                   Foreground="{StaticResource BrushAccent}"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsServerStarting, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!-- Center: Save confirmation -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ShowSaveConfirmation, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding SaveConfirmationText}"
                                   Style="{StaticResource TextCaption}"
                                   Foreground="{StaticResource BrushSuccess}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[OpenFolderLink]}"
                                   Style="{StaticResource TextCaption}"
                                   Foreground="{StaticResource BrushAccent}"
                                   Cursor="Hand"
                                   TextDecorations="Underline"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSavedFolderCommand}" />
                            </TextBlock.InputBindings>
                        </TextBlock>
                        <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ExportOpenWorkbook]}"
                                   Style="{StaticResource TextCaption}"
                                   Foreground="{StaticResource BrushAccent}"
                                   Cursor="Hand"
                                   TextDecorations="Underline"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSavedFileCommand}" />
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </StackPanel>

                    <!-- Export + Clear buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ExportButton"
                                Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BtnExportExcel]}"
                                Style="{StaticResource ButtonPrimaryStyle}"
                                Padding="16,8"
                                Margin="0,0,8,0"
                                Command="{Binding ExportExcelCommand}"
                                ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BtnExportTooltip]}" />
                        <Button Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BtnClear]}"
                                Style="{StaticResource ButtonSecondaryStyle}"
                                Padding="16,8"
                                Command="{Binding ClearCommand}"
                                ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[BtnClearTooltip]}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ ONBOARDING OVERLAY (coach-mark) ══ -->
        <!-- Background set to transparent (not #80000000) so the overlay does not
             intercept clicks on the title-bar close button underneath. The dim
             backdrop is provided by a Rectangle inside the Canvas that has
             IsHitTestVisible="False", allowing mouse events to pass through. -->
        <Border x:Name="OnboardingOverlay"
                Grid.ColumnSpan="2"
                Panel.ZIndex="900"
                Visibility="Collapsed"
                IsHitTestVisible="True">
            <!-- Canvas for absolute positioning of dim backdrop, spotlight + callout -->
            <Canvas>
                <!-- Dim backdrop (not hit-testable — clicks pass through to close button) -->
                <Rectangle x:Name="OnboardingDim"
                           Fill="#80000000"
                           Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                           Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"
                           IsHitTestVisible="False"
                           Canvas.ZIndex="0" />
                <!-- Spotlight highlight ring around target element -->
                <Border x:Name="OnboardingSpotlight"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="2.5"
                        CornerRadius="8"
                        Opacity="0"
                        Canvas.ZIndex="1" />

                <!-- Callout box -->
                <Border x:Name="OnboardingCallout"
                        Style="{StaticResource CardStyle}"
                        Width="320"
                        Opacity="0"
                        Canvas.ZIndex="2">
                    <StackPanel>
                        <TextBlock x:Name="OnboardingStepLabel"
                                   Style="{StaticResource TextCaption}"
                                   Foreground="{StaticResource BrushAccent}"
                                   FontWeight="{StaticResource FontWeightMedium}"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="OnboardingTitle"
                                   Style="{StaticResource TextCardTitle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="OnboardingDesc"
                                   Style="{StaticResource TextBody}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="OnboardingSkipBtn"
                                    Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[OnboardingSkip]}"
                                    Style="{StaticResource ButtonSecondaryStyle}"
                                    MinWidth="80"
                                    Margin="0,0,8,0"
                                    Click="OnboardingSkip_Click" />
                            <Button x:Name="OnboardingNextBtn"
                                    Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[OnboardingNext]}"
                                    Style="{StaticResource ButtonPrimaryStyle}"
                                    MinWidth="80"
                                    Click="OnboardingNext_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Canvas>
        </Border>

        <!-- ══ UPDATE CHECK NOTIFICATION ══ -->
        <Border x:Name="UpdateNotification"
                Grid.Column="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushAccent}"
                BorderThickness="0,2,0,0"
                Padding="24,10"
                VerticalAlignment="Bottom"
                Panel.ZIndex="800"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="8" Height="8"
                        CornerRadius="4"
                        Background="{StaticResource BrushAccent}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0" />
                <TextBlock Grid.Column="1"
                           x:Name="UpdateNotificationText"
                           Style="{StaticResource TextCaption}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Grid.Column="2"
                        x:Name="UpdateDownloadBtn"
                        Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[UpdateCheckReleaseLink]}"
                        Style="{StaticResource ButtonPrimaryStyle}"
                        MinWidth="120"
                        Padding="12,6"
                        Margin="16,0,8,0"
                        FontSize="12"
                        Click="UpdateDownload_Click" />
                <Button Grid.Column="3"
                        Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[UpdateCheckDismiss]}"
                        Style="{StaticResource ButtonSecondaryStyle}"
                        MinWidth="60"
                        Padding="8,6"
                        FontSize="12"
                        Click="UpdateDismiss_Click" />
            </Grid>
        </Border>

        <!-- ══ SERVER OVERLAY (crashed / starting) ══ -->
        <Border Grid.ColumnSpan="2"
                Background="{StaticResource BrushOverlay}"
                Panel.ZIndex="1000"
                Visibility="{Binding ShowServerDiedOverlay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource DialogStyle}"
                    Width="440"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Geometric composition -->
                    <Grid Width="48" Height="48" Margin="0,0,0,24">
                        <Border Width="48" Height="48"
                                Background="{StaticResource BrushAccentLight}"
                                CornerRadius="12" />
                        <Border Width="16" Height="16"
                                Background="{StaticResource BrushAccent}"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                    </Grid>

                    <!-- Title changes based on state -->
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ServerDiedTitle]}"
                               Style="{StaticResource TextSectionHeading}"
                               HorizontalAlignment="Center"
                               Visibility="{Binding IsServerStarting, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ServerDiedRestarting]}"
                               Style="{StaticResource TextSectionHeading}"
                               HorizontalAlignment="Center"
                               Visibility="{Binding IsServerStarting, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <!-- Status description -->
                    <TextBlock Text="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ServerDiedDescription]}"
                               Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Visibility="{Binding IsServerStarting, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <!-- Starting progress status -->
                    <TextBlock Text="{Binding ServerStartingStatus}"
                               Style="{StaticResource TextBody}"
                               Foreground="{StaticResource BrushAccent}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Visibility="{Binding IsServerStarting, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,0">
                        <!-- Retry button (hidden while starting) -->
                        <Button Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ServerDiedRestartBtn]}"
                                Style="{StaticResource ButtonPrimaryStyle}"
                                Width="180"
                                Margin="0,0,12,0"
                                Command="{Binding RetryServerCommand}"
                                ToolTip="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ServerDiedRestartTooltip]}"
                                Visibility="{Binding IsServerStarting, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <!-- Close button -->
                        <Button Content="{Binding Source={x:Static ui:TranslationSource.Instance}, Path=[ServerDiedCloseBtn]}"
                                Style="{StaticResource ButtonDangerStyle}"
                                Width="180"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml" />
        <ResourceDictionary Source="Spacing.xaml" />
        <ResourceDictionary Source="Animations.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════
         HOTIX Card Styles — Premium
         Consistent: radius 16, same border/shadow/padding
         Hover: subtle 1px lift
         ═══════════════════════════════════════════════ -->

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius"    Value="{StaticResource RadiusLarge}" />
        <Setter Property="Padding"         Value="{StaticResource PaddingCard}" />
        <Setter Property="Effect"          Value="{StaticResource ShadowCard}" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard Storyboard="{StaticResource StoryboardCardHoverEnter}" />
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard Storyboard="{StaticResource StoryboardCardHoverLeave}" />
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CardStyleCompact" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="{StaticResource PaddingCardCompact}" />
    </Style>

    <!-- Card step header (step number + title) -->
    <Style x:Key="CardStepHeader" TargetType="TextBlock" BasedOn="{StaticResource TextCardTitle}">
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Card label (above inputs within cards) -->
    <Style x:Key="CardLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- Step indicator badge -->
    <Style x:Key="StepBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
        <Setter Property="Background" Value="{StaticResource BrushAccentLight}" />
    </Style>

</ResourceDictionary>

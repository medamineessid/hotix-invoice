<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════
         HOTIX Spacing — 8-Point Grid System
         Allowed: 8, 12, 16, 24, 32, 48, 64, 96
         ═══════════════════════════════════════════════ -->

    <!-- Base spacing units -->
    <Thickness x:Key="Spacing0">0</Thickness>
    <Thickness x:Key="Spacing4">4</Thickness>
    <Thickness x:Key="Spacing8">8</Thickness>
    <Thickness x:Key="Spacing12">12</Thickness>
    <Thickness x:Key="Spacing16">16</Thickness>
    <Thickness x:Key="Spacing24">24</Thickness>
    <Thickness x:Key="Spacing32">32</Thickness>
    <Thickness x:Key="Spacing48">48</Thickness>
    <Thickness x:Key="Spacing64">64</Thickness>
    <Thickness x:Key="Spacing96">96</Thickness>

    <!-- Padding presets -->
    <Thickness x:Key="PaddingCard">24</Thickness>
    <Thickness x:Key="PaddingCardCompact">16</Thickness>
    <Thickness x:Key="PaddingButton">14,10</Thickness>
    <Thickness x:Key="PaddingButtonWide">24,14</Thickness>
    <Thickness x:Key="PaddingInput">14,12</Thickness>
    <Thickness x:Key="PaddingNavItem">16</Thickness>
    <Thickness x:Key="PaddingDialog">32</Thickness>

    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusNone">0</CornerRadius>
    <CornerRadius x:Key="RadiusSmall">8</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">14</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">20</CornerRadius>
    <CornerRadius x:Key="RadiusFull">9999</CornerRadius>

    <!-- Margins -->
    <Thickness x:Key="MarginWindowEdge">32</Thickness>
    <Thickness x:Key="MarginSectionBottom">32</Thickness>
    <Thickness x:Key="MarginElementBottom">16</Thickness>
    <Thickness x:Key="MarginInline">12</Thickness>

    <!-- Row heights -->
    <GridLength x:Key="RowHeightNavItem">48</GridLength>
    <sys:Double x:Key="NavItemHeightPx">48</sys:Double>
    <GridLength x:Key="RowHeightInput">44</GridLength>
    <GridLength x:Key="RowHeightStatusBar">44</GridLength>

    <!-- Sidebar width -->
    <GridLength x:Key="SidebarWidth">260</GridLength>
    <sys:Double x:Key="SidebarWidthPx">260</sys:Double>

</ResourceDictionary>

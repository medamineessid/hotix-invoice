<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════
         HOTIX Color Palette — Premium Edition
         Inspired by Apple HIG, Linear, Suprematism
         ═══════════════════════════════════════════════ -->

    <!-- Backgrounds — warm, natural, premium -->
    <Color x:Key="ColorBackground">#F8F7F4</Color>
    <Color x:Key="ColorAltBackground">#F3F2EE</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorSidebar">#F8F7F4</Color>

    <!-- Borders & Dividers — barely there -->
    <Color x:Key="ColorBorder">#E8E7E2</Color>
    <Color x:Key="ColorBorderLight">#EEEDE8</Color>

    <!-- Text — near-black, no pure black. Contrast ratios on #F8F7F4 bg:
         Primary: 15.4:1 (AAA)
         Secondary: 5.5:1 (AA) — was 4.4:1 at #666666
         Muted: 3.5:1 (for non-essential/decorative only)
         Placeholder: 2.3:1 (for empty-state hints, not critical text) -->
    <Color x:Key="ColorTextPrimary">#1A1A1A</Color>
    <Color x:Key="ColorTextSecondary">#555555</Color>
    <Color x:Key="ColorTextMuted">#8A8A8A</Color>
    <Color x:Key="ColorTextInverse">#FFFFFF</Color>
    <Color x:Key="ColorTextPlaceholder">#B8B8B8</Color>

    <!-- Accent — HOTIX Signature Red (primary CTAs + danger indicator)
         The hotix brand uses red for primary actions. We visually distinguish
         danger from primary by using a darker shade for errors (#B71C1C). -->
    <Color x:Key="ColorAccent">#D9472B</Color>
    <Color x:Key="ColorAccentHover">#C03A20</Color>
    <Color x:Key="ColorAccentLight">#FDF0ED</Color>
    <Color x:Key="ColorAccentBg">#FFF5F3</Color>

    <!-- Functional colors — softer, more refined
         Error (#B71C1C) is visually distinct from Accent (#D9472B)
         to differentiate destructive actions from primary CTAs -->
    <Color x:Key="ColorSuccess">#2E7D32</Color>
    <Color x:Key="ColorWarning">#E67E22</Color>
    <Color x:Key="ColorError">#B71C1C</Color>
    <Color x:Key="ColorInfo">#1565C0</Color>

    <!-- Pastel confidence colors (for badges) -->
    <Color x:Key="ColorConfidenceHighBg">#E8F5E9</Color>
    <Color x:Key="ColorConfidenceHighText">#2E7D32</Color>
    <Color x:Key="ColorConfidenceMediumBg">#FFF3E0</Color>
    <Color x:Key="ColorConfidenceMediumText">#E65100</Color>
    <Color x:Key="ColorConfidenceLowBg">#FFEBEE</Color>
    <Color x:Key="ColorConfidenceLowText">#C62828</Color>

    <!-- Interaction states -->
    <Color x:Key="ColorHover">#F0EFEA</Color>
    <Color x:Key="ColorSelected">#EBE9E3</Color>
    <Color x:Key="ColorPressed">#E3E0D8</Color>

    <!-- Shadows -->
    <Color x:Key="ColorShadow">#000000</Color>

    <!-- Overlay -->
    <Color x:Key="ColorOverlay">#000000</Color>

    <!-- Geometric accent shapes -->
    <Color x:Key="ColorGeometricFill">#E8E7E2</Color>
    <Color x:Key="ColorGeometricStroke">#D4D2CC</Color>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml" />
        <ResourceDictionary Source="Spacing.xaml" />
        <ResourceDictionary Source="Animations.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════
         HOTIX Dialog Styles — Premium
         Open: fade + scale 0.95→1.0 (250ms)
         Close: reverse (180ms)
         Radius 16 to match cards
         ═══════════════════════════════════════════════ -->

    <Style x:Key="DialogOverlayStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushOverlay}" />
    </Style>

    <Style x:Key="DialogStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BrushSurface}" />
        <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius"    Value="{StaticResource RadiusLarge}" />
        <Setter Property="Padding"         Value="{StaticResource PaddingDialog}" />
        <Setter Property="Effect"          Value="{StaticResource ShadowDialog}" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                    <TranslateTransform />
                </TransformGroup>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource StoryboardDialogOpen}" />
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DialogTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource TextSectionHeading}">
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="DialogBodyStyle" TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,24" />
    </Style>

    <Style x:Key="DialogFooterStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

</ResourceDictionary>

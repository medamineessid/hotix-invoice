<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════
         HOTIX Brushes
         ═══════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BrushBackground"     Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="BrushAltBackground"   Color="{StaticResource ColorAltBackground}" />
    <SolidColorBrush x:Key="BrushSurface"         Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSidebar"         Color="{StaticResource ColorSidebar}" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BrushBorder"          Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushBorderLight"     Color="{StaticResource ColorBorderLight}" />

    <!-- Text -->
    <SolidColorBrush x:Key="BrushTextPrimary"     Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary"   Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMuted"       Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="BrushTextInverse"     Color="{StaticResource ColorTextInverse}" />
    <SolidColorBrush x:Key="BrushTextPlaceholder" Color="{StaticResource ColorTextPlaceholder}" />

    <!-- Accent -->
    <SolidColorBrush x:Key="BrushAccent"          Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentHover"     Color="{StaticResource ColorAccentHover}" />
    <SolidColorBrush x:Key="BrushAccentLight"     Color="{StaticResource ColorAccentLight}" />

    <!-- Functional -->
    <SolidColorBrush x:Key="BrushSuccess"         Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushWarning"         Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="BrushError"           Color="{StaticResource ColorError}" />
    <SolidColorBrush x:Key="BrushInfo"            Color="{StaticResource ColorInfo}" />

    <!-- Interaction -->
    <SolidColorBrush x:Key="BrushHover"           Color="{StaticResource ColorHover}" />
    <SolidColorBrush x:Key="BrushSelected"        Color="{StaticResource ColorSelected}" />
    <SolidColorBrush x:Key="BrushPressed"         Color="{StaticResource ColorPressed}" />

    <!-- Shadows -->
    <DropShadowEffect x:Key="ShadowCard" 
                      ShadowDepth="2" 
                      Direction="270" 
                      BlurRadius="12" 
                      Opacity="0.08" 
                      Color="{StaticResource ColorShadow}" />
    <DropShadowEffect x:Key="ShadowCardHover"
                      ShadowDepth="4"
                      Direction="270"
                      BlurRadius="20"
                      Opacity="0.12"
                      Color="{StaticResource ColorShadow}" />
    <DropShadowEffect x:Key="ShadowButton"
                      ShadowDepth="1"
                      Direction="270"
                      BlurRadius="4"
                      Opacity="0.10"
                      Color="{StaticResource ColorShadow}" />
    <DropShadowEffect x:Key="ShadowDialog"
                      ShadowDepth="8"
                      Direction="270"
                      BlurRadius="32"
                      Opacity="0.15"
                      Color="{StaticResource ColorShadow}" />
    <DropShadowEffect x:Key="ShadowSidebar"
                      ShadowDepth="0"
                      Direction="90"
                      BlurRadius="8"
                      Opacity="0.06"
                      Color="{StaticResource ColorShadow}" />

    <!-- Overlay -->
    <SolidColorBrush x:Key="BrushOverlay"         Color="{StaticResource ColorOverlay}" Opacity="0.35" />

    <!-- Confidence -->
    <SolidColorBrush x:Key="BrushConfidenceHigh"   Color="{StaticResource ColorConfidenceHigh}" />
    <SolidColorBrush x:Key="BrushConfidenceMedium" Color="{StaticResource ColorConfidenceMedium}" />
    <SolidColorBrush x:Key="BrushConfidenceLow"    Color="{StaticResource ColorConfidenceLow}" />

    <!-- Geometric -->
    <SolidColorBrush x:Key="BrushGeometricFill"    Color="{StaticResource ColorGeometricFill}" />
    <SolidColorBrush x:Key="BrushGeometricStroke"  Color="{StaticResource ColorGeometricStroke}" />

    <!-- Primary button -->
    <SolidColorBrush x:Key="BrushButtonPrimary"         Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushButtonPrimaryHover"    Color="#2A2A2A" />
    <SolidColorBrush x:Key="BrushButtonPrimaryPressed"  Color="#333333" />

    <!-- Secondary button -->
    <SolidColorBrush x:Key="BrushButtonSecondary"         Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushButtonSecondaryStroke"   Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushButtonSecondaryHover"    Color="{StaticResource ColorHover}" />

    <!-- Danger button -->
    <SolidColorBrush x:Key="BrushButtonDanger"         Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushButtonDangerHover"    Color="{StaticResource ColorAccentHover}" />

    <!-- Input -->
    <SolidColorBrush x:Key="BrushInputBackground"     Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushInputBorder"         Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushInputBorderHover"    Color="#C0BFBA" />
    <SolidColorBrush x:Key="BrushInputBorderFocus"    Color="{StaticResource ColorTextPrimary}" />

</ResourceDictionary>

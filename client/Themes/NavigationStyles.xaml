<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml" />
        <ResourceDictionary Source="Spacing.xaml" />
        <ResourceDictionary Source="Typography.xaml" />
        <ResourceDictionary Source="Animations.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════
         HOTIX Navigation Styles — Premium
         Sidebar: 240px, border-right, no heavy shadows
         Active nav: soft red bg, rounded, subtle
         Icons: same style, consistent weight
         ═══════════════════════════════════════════════ -->

    <!-- Sidebar container -->
    <Style x:Key="SidebarStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushSidebar}" />
        <Setter Property="Width"      Value="240" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <!-- Nav item container — inactive state -->
    <Style x:Key="NavItemStyle" TargetType="Border">
        <Setter Property="Height"          Value="44" />
        <Setter Property="CornerRadius"    Value="{StaticResource RadiusMedium}" />
        <Setter Property="Padding"         Value="12,0,12,0" />
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Cursor"          Value="Hand" />
    </Style>

    <!-- Nav item container — active state (soft red bg) -->
    <Style x:Key="NavItemStyleActive" TargetType="Border" BasedOn="{StaticResource NavItemStyle}">
        <Setter Property="Background" Value="{StaticResource BrushAccentBg}" />
    </Style>

    <!-- Nav icon (all same stroke width, 16px) -->
    <Style x:Key="NavIconStyle" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontSize"      Value="16" />
        <Setter Property="FontWeight"    Value="{StaticResource FontWeightRegular}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"        Value="0,0,10,0" />
    </Style>

    <!-- Active nav icon -->
    <Style x:Key="NavIconActiveStyle" TargetType="TextBlock" BasedOn="{StaticResource NavIconStyle}">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}" />
    </Style>

    <!-- Nav text — inactive -->
    <Style x:Key="NavTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontFamily"    Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize"      Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontWeight"    Value="{StaticResource FontWeightRegular}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Nav text — selected/active -->
    <Style x:Key="NavTextSelectedStyle" TargetType="TextBlock" BasedOn="{StaticResource NavTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}" />
    </Style>

    <!-- Sidebar section label -->
    <Style x:Key="SidebarSectionLabel" TargetType="TextBlock" BasedOn="{StaticResource TextTiny}">
        <Setter Property="Padding" Value="12,24,12,8" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
    </Style>

    <!-- Logo area text -->
    <Style x:Key="SidebarLogoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize"   Value="22" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
    </Style>

    <!-- Sidebar footer text -->
    <Style x:Key="SidebarFooterStyle" TargetType="TextBlock" BasedOn="{StaticResource TextTiny}">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml" />
        <ResourceDictionary Source="Spacing.xaml" />
        <ResourceDictionary Source="Typography.xaml" />
        <ResourceDictionary Source="Animations.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════
         HOTIX Navigation Styles
         Sidebar: 260px, no visible border
         Nav items: height 48, radius 14, padding 16
         Selected: 2px black indicator + small red square
         ═══════════════════════════════════════════════ -->

    <!-- Sidebar container -->
    <Style x:Key="SidebarStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushSidebar}" />
        <Setter Property="Width"      Value="{StaticResource SidebarWidth}" />
        <Setter Property="Effect"     Value="{StaticResource ShadowSidebar}" />
    </Style>

    <!-- Nav item container -->
    <Style x:Key="NavItemStyle" TargetType="Border">
        <Setter Property="Height"          Value="{StaticResource RowHeightNavItem}" />
        <Setter Property="CornerRadius"    Value="{StaticResource RadiusMedium}" />
        <Setter Property="Padding"         Value="{StaticResource PaddingNavItem}" />
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- Nav item indicator (2px vertical black line) -->
    <Style x:Key="NavIndicatorStyle" TargetType="Border">
        <Setter Property="Width"            Value="2" />
        <Setter Property="Height"           Value="0" />
        <Setter Property="Background"       Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="CornerRadius"     Value="1" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment"   Value="Center" />
    </Style>

    <!-- Nav item red square accent -->
    <Style x:Key="NavRedSquareStyle" TargetType="Border">
        <Setter Property="Width"            Value="6" />
        <Setter Property="Height"           Value="6" />
        <Setter Property="Background"       Value="{StaticResource BrushAccent}" />
        <Setter Property="CornerRadius"     Value="1" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment"   Value="Center" />
        <Setter Property="Margin"           Value="0,0,12,0" />
        <Setter Property="Opacity"          Value="0" />
    </Style>

    <!-- Nav icon (thin outline style) -->
    <Style x:Key="NavIconStyle" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontSize"      Value="16" />
        <Setter Property="FontWeight"    Value="{StaticResource FontWeightLight}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"        Value="0,0,12,0" />
    </Style>

    <!-- Nav text -->
    <Style x:Key="NavTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground"    Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontFamily"    Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize"      Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontWeight"    Value="{StaticResource FontWeightRegular}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Selected nav text -->
    <Style x:Key="NavTextSelectedStyle" TargetType="TextBlock" BasedOn="{StaticResource NavTextStyle}">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}" />
    </Style>

    <!-- Sidebar section label -->
    <Style x:Key="SidebarSectionLabel" TargetType="TextBlock" BasedOn="{StaticResource TextMetadata}">
        <Setter Property="Padding" Value="16,24,16,8" />
    </Style>

    <!-- Logo area -->
    <Style x:Key="SidebarLogoStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontDisplay}" />
        <Setter Property="FontSize"   Value="20" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeightLight}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
    </Style>

    <!-- Inspirational quote -->
    <Style x:Key="SidebarQuoteStyle" TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <!-- Sidebar footer -->
    <Style x:Key="SidebarFooterStyle" TargetType="TextBlock" BasedOn="{StaticResource TextMetadata}">
        <Setter Property="Opacity" Value="0.4" />
    </Style>

</ResourceDictionary>
